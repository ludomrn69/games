{
  "rules": {
    "games": {
      "rooms": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["createdAt"],
        "$code": {
          ".validate": "$code.length >= 3 && $code.length <= 8",
          "game": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "status": { ".validate": "newData.isString() && newData.val().length <= 16" },
          "host": { ".validate": "newData.isString() && newData.val().length <= 128" },
          "players": {
            "$pid": {
              ".validate": "$pid.length <= 128",
              "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
              "emoji": { ".validate": "newData.isString() && newData.val().length <= 24" },
              "color": { ".validate": "newData.isString() && newData.val().length <= 40" }
            }
          }
        }
      },
      "private": {
        "$code": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      },
      "$other": { ".validate": false }
    }
  }
}
