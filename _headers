/*
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://*.firebasedatabase.app wss://*.firebasedatabase.app https://*.googleapis.com https://www.gstatic.com; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

# Pages HTML : jamais servies depuis le cache sans revérifier (évite un vieux
# HTML qui ferait beuguer Firebase/lobby).
/*.html
  Cache-Control: no-cache
/games/*
  Cache-Control: no-cache
/
  Cache-Control: no-cache

# Scripts partagés : toujours revérifiés (toutes les pages en dépendent).
/firebase-init.js
  Cache-Control: no-cache
/lobby.js
  Cache-Control: no-cache
/presence.js
  Cache-Control: no-cache
/avatars.js
  Cache-Control: no-cache
/nav.js
  Cache-Control: no-cache
/offline.js
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache
/theme.css
  Cache-Control: no-cache
/game.css
  Cache-Control: no-cache
